#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/../sample_project"
BACKUP_DIR="$SCRIPT_DIR/../backups"
RETAIN=2

mkdir -p "$BACKUP_DIR"

timestamp=$(date '+%Y%m%d_%H%M%S')
archive_name="sample_project_backup_$timestamp.tar.gz"

tar -czf "$BACKUP_DIR/$archive_name" -C "$PROJECT_DIR" .
echo "Created backup: $archive_name"

# Prune old backups, keep only newest $RETAIN
cd "$BACKUP_DIR"
backup_count=$(ls -1 sample_project_backup_*.tar.gz 2>/dev/null | wc -l)

if [ "$backup_count" -gt "$RETAIN" ]; then
    ls -1t sample_project_backup_*.tar.gz | tail -n +$((RETAIN + 1)) | while read -r old_backup; do
        echo "Pruning old backup: $old_backup"
        rm -f "$old_backup"
    done
fi

echo "Current backups:"
ls -lt "$BACKUP_DIR"
