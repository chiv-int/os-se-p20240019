#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STOCK_FILE="$SCRIPT_DIR/../stock.txt"
LOG_FILE="$SCRIPT_DIR/../sales_log.txt"
LOCK_FILE="$SCRIPT_DIR/../stock.lock"
STUDENT_ID="p20240019"

buyer="$1"
qty="$2"

if [ -z "$buyer" ] || [ -z "$qty" ]; then
    echo "Usage: buy_beacon <buyer_name> <quantity>"
    exit 1
fi

if ! [[ "$qty" =~ ^[0-9]+$ ]] || [ "$qty" -le 0 ]; then
    echo "Error: quantity must be a positive integer."
    exit 1
fi

(
    flock -x 200

    current_stock=$(cat "$STOCK_FILE")

    if [ "$qty" -le "$current_stock" ]; then
        new_stock=$((current_stock - qty))
        echo "$new_stock" > "$STOCK_FILE"
        echo "$(date '+%Y-%m-%d %H:%M:%S') | buyer=$buyer | qty=$qty | student_id=$STUDENT_ID | remaining_stock=$new_stock" >> "$LOG_FILE"
        echo "Purchase successful: $buyer bought $qty Beacon(s). Remaining stock: $new_stock"
    else
        echo "Purchase failed: not enough stock for $buyer (requested $qty, available $current_stock)"
    fi

) 200>"$LOCK_FILE"

if [ "$1" -gt 4 ]; then
    echo "Order rejected: Per-buyer cap of 4 exceeded."
    exit 1
fi
